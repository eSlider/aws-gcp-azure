# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=

# GCP
# Leave GCP_PROJECT_ID empty to auto-detect via gcloud projects list
# Use us-central1 (or us-east1 / us-west1) for Cloud Storage free tier — see docs/FREE-TIER.md
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Azure
# Tenant from: az login error / Entra ID portal
AZURE_TENANT_ID=
ARM_SUBSCRIPTION_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
AZURE_LOCATION=westeurope

RESOURCE_PREFIX=minimal-health
